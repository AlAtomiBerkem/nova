# ============================================================
#  NOVA — переменные окружения. Скопируй в .env и заполни.
#  cp .env.example .env
# ============================================================

# --- PostgreSQL (docker-compose сам поднимет БД с этими кредами) ---
POSTGRES_USER=nova
POSTGRES_PASSWORD=nova
POSTGRES_DB=nova

# --- порт, на котором наружу торчит сайт (nginx) ---
WEB_PORT=8080

# --- порт Postgres на хосте (для миграций/Prisma Studio; смени, если 5432 занят) ---
DB_PORT=5433

# --- секрет для подписи JWT админки (сгенерируй: openssl rand -hex 32) ---
JWT_SECRET=replace-with-long-random-string

# --- какие origin'ы фронта пускать в CORS (через запятую) ---
CORS_ORIGINS=http://localhost:8080

# --- соль для хеширования IP (антиспам). openssl rand -hex 16 ---
IP_HASH_SALT=replace-me

# --- учётка админа (для `npm run seed` / разового создания) ---
ADMIN_EMAIL=admin@nova.local
ADMIN_PASSWORD=replace-with-strong-password
ADMIN_NAME=NOVA

# --- публичный URL админки (для ссылок в уведомлениях) ---
ADMIN_URL=http://localhost:8080/admin.html

# ============================================================
#  Локальная разработка backend без docker (backend/.env):
#  DATABASE_URL="postgresql://nova:nova@localhost:5432/nova?schema=public"
# ============================================================

# --- УВЕДОМЛЕНИЯ. Каждый канал активен только при заполненных ключах. ---

# Telegram (самый быстрый): @BotFather → токен; chat_id узнать у @userinfobot
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Web-push (VAPID). Сгенерировать: cd backend && npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@nova.local

# Email (резерв) через Resend: https://resend.com → API key
# RESEND_API_KEY=
# RESEND_FROM=NOVA <onboarding@resend.dev>
# RESEND_TO=you@example.com

# --- АНТИСПАМ ---
# Лимит запросов с одного IP за окно:
RATE_WINDOW_MS=60000
RATE_MAX=10
# Капча Cloudflare Turnstile (если задан секрет — проверяется на создании лида).
# Также пропиши site key во фронте (см. README).
# TURNSTILE_SECRET=
