# ============================================================
#  NOVA — переменные окружения. Скопируй в .env и заполни.
#  cp .env.example .env
# ============================================================

# --- PostgreSQL (docker-compose сам поднимет БД с этими кредами) ---
POSTGRES_USER=nova
POSTGRES_PASSWORD=nova
POSTGRES_DB=nova

# --- порт, на котором наружу торчит сайт (nginx) ---
WEB_PORT=8080

# --- секрет для подписи JWT админки (сгенерируй: openssl rand -hex 32) ---
JWT_SECRET=replace-with-long-random-string

# --- какие origin'ы фронта пускать в CORS (через запятую) ---
CORS_ORIGINS=http://localhost:8080

# --- соль для хеширования IP (антиспам). openssl rand -hex 16 ---
IP_HASH_SALT=replace-me

# ============================================================
#  Локальная разработка backend без docker (backend/.env):
#  DATABASE_URL="postgresql://nova:nova@localhost:5432/nova?schema=public"
# ============================================================

# --- уведомления (Этап 7, заполнить позже) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# RESEND_API_KEY=

# --- капча Turnstile (Этап 8) ---
# TURNSTILE_SECRET=
